# Paneler environment variables. Copy to `.env.local` for local dev.
# See README.md "Data persistence" for the full mode table.

# ── Auth (optional) ───────────────────────────────────────────────────────
# When AUTH_SECRET is unset, the proxy admits every /app/* request — the
# default for local dev. Set the same secret as paneler-business to enable
# the shared-cookie OIDC sign-in flow.
# AUTH_SECRET=

# When true, the proxy bypass is on even if AUTH_SECRET is set. Required
# alongside DATABASE_URL in local dev so the designs API accepts requests
# without a session.
AUTH_DISABLED=true

# ── Database (optional) ───────────────────────────────────────────────────
# Set to enable the left-nav designs list and per-user persistence.
# Without it, the app runs files-only (export/import JSON, URL-hash share).
# Local docker-compose target:
# DATABASE_URL=postgres://paneler:paneler@localhost:5432/paneler

# ── Static export (CI only; don't set locally) ────────────────────────────
# STATIC_EXPORT=1 produces an `out/` directory suitable for GitHub Pages.
# Disables the API routes and DB code via next.config.ts aliasing.
# STATIC_EXPORT=
